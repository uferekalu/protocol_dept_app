# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/protocol_department

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=1d

# CORS
FRONTEND_URL=http://localhost:3000

# Cloudinary (profile photo upload)
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@<your_cloud_name>

# Termii (SMS)
TERMII_API_KEY=replace_this_with_your_termii_api_key
TERMII_BASE_URL=https://v4.api.termii.com
# "Termii"/"generic" work without sender-ID registration approval — swap in a
# custom registered sender ID + "dnd" channel once one is approved.
TERMII_SENDER_ID=Termii
TERMII_CHANNEL=generic
